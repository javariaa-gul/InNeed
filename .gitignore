# ============================================================================
# APKA HUNAR - Global .gitignore
# ============================================================================

# ─── Environment Variables ────────────────────────────────────────────────
# Never commit environment files with actual credentials
.env
.env.local
.env.production
.env.staging
.env*.local
.env.development

# ─── Node Modules ─────────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
.npm

# ─── Build Artifacts ──────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ─── IDE & Editor Files ───────────────────────────────────────────────────
.vscode/
.idea/
.eclipse
*.swp
*.swo
*~
.DS_Store
.classpath
.project
.settings/
*.sublime-workspace
*.sublime-project
.c9/
*.SubscriptCommand

# ─── Operating System ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem
*.key

# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ─── Database ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
postgres_data/

# ─── Docker ───────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ─── Sensitive Files ──────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
private/
secrets/
credentials.json
service-account*.json

# ─── Test Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ─── OS Specific ──────────────────────────────────────────────────────────
.env.local.php
.env.*.local
local.xml

# ─── Backup Files ─────────────────────────────────────────────────────────
*.bak
*.backup
*.tmp
*~

# ─── Package Manager ──────────────────────────────────────────────────────
.pnp
.pnp.js
