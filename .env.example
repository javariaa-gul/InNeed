# Apka Hunar environment example

# Database (used by backend and optionally AI service)
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=apka_hunar_user
DATABASE_PASSWORD=change_this_password
DATABASE_NAME=apka_hunar

# PgAdmin (optional local database admin)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Backend / Gateway
PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_secret_to_at_least_32_characters_long
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=error,warn,log

# Service URLs
AI_SERVICE_URL=http://ai-service:8000
BLOCKCHAIN_SERVICE_URL=http://blockchain-service:3001

# Cloudinary (required only if you use image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
